#include <Servo.h>

Servo servo1; 
Servo servo2;  
Servo servo3; 
Servo servo4; 

int pos = 0;               
int time = 0;              // to calculate ms
bool timescontinue = true; // to stop after 2s

void setup() { // initals all servo
  servo1.attach(2); 
  servo2.attach(3);
  servo3.attach(4);
  servo4.attach(5);  
}

void loop() {
  while(timescontinue){
      for (pos = 0; pos <= 180; pos += 1) { // goes from 0 degrees to 180 degrees
        servo1.write(pos);              // tell servo to go to position in variable 'pos'
        servo2.write(pos); 
        servo3.write(pos); 
        servo4.write(pos); 
        delay(10);                       // waits 10 ms for the servo to reach the position
        time += 10;
      }
      for (pos = 180; pos >= 0; pos -= 1) { // goes from 180 degrees to 0 degrees
        servo1.write(pos);              // tell servo to go to position in variable 'pos'
        servo2.write(pos); 
        servo3.write(pos); 
        servo4.write(pos); 
        delay(10);                       // waits 10 ms for the servo to reach the position
        time += 10;                       // waits 15 ms for the servo to reach the position
      }

      if (time > 2000){                 // if time reach to 2s
        servo1.write(90);              // tell servo to go to position in variable 'pos'
        servo2.write(90); 
        servo3.write(90); 
        servo4.write(90);
        timescontinue = false;
      }
  }
}
